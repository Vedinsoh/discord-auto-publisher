# Development Dockerfile for bot-api with hot reloading
FROM oven/bun:1.2.22-alpine

# Create app user for security
RUN addgroup -g 1001 -S nodejs
RUN adduser -S app -u 1001

WORKDIR /app

# Copy workspace configuration and package files
COPY package.json bun.lock turbo.json ./
COPY packages/ ./packages/
COPY apps/bot-api/package.json ./apps/bot-api/package.json

# Install all dependencies (including dev dependencies)
RUN bun install --no-optional

# Copy remaining source code (will be overridden by volume mount in dev)
COPY . .

# Expose port
EXPOSE 8080

# Start in development mode with watch
WORKDIR /app/apps/bot-api
CMD ["bun", "--watch", "./src/index.ts"]