generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

model Guilds {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  guildId          String   @unique
  updatesChannelId String?
  isMigrated       Boolean?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Channels {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  channelId String   @unique
  guildId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guildId])
}
