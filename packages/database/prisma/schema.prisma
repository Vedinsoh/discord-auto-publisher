generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

model Guilds {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  guildId   String   @unique
  channels  String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
