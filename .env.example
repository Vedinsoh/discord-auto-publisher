# Copy this file to .env.local for development or .env.production for production

# Common
DISCORD_TOKEN = "YOUR_DISCORD_APP_TOKEN" # Discord app token
APP_EDITION = "free" # Edition of the app: "free" or "premium"

# Backend
DATABASE_URL = "postgresql://postgres:postgres@host.docker.internal:54322/postgres" # Supabase connection string

# Bot core
BOT_SUPPORT_GUILD_ID = "YOUR_SUPPORT_GUILD_ID" # Your bot's support server ID
BOT_SHARDS = 1 # Number of shards to spawn
BOT_SHARDS_PER_CLUSTER = 1 # Number of shards per cluster

# Web App
AUTH_SECRET = "" # Generate with: npx auth secret
DISCORD_CLIENT_ID = "" # Discord OAuth app client ID
DISCORD_CLIENT_SECRET = "" # Discord OAuth app client secret
FREE_BACKEND_URL = "http://localhost:3101" # Free backend URL
PREMIUM_BACKEND_URL = "http://localhost:3102" # Premium backend URL
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN = "" # Paddle client-side token
NEXT_PUBLIC_PADDLE_ENVIRONMENT = "sandbox" # sandbox or production
NEXT_PUBLIC_PREMIUM_BOT_CLIENT_ID = "" # Premium Discord bot client ID