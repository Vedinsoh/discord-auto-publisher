# Copy this file to .env.local for development or .env.production for production

# Common
DISCORD_TOKEN = "your_discord_bot_token_here" # Discord bot token

# Bot API
REDIS_URI = "redis://bot-api-cache:6379" # Redis connection string
MONGO_URI = "mongodb://mongo:27017/discord-bot" # MongoDB connection string
REST_HOST = "localhost" # Hostname for the server
REST_PORT = "8080" # The port your server will listen on

# Bot core
BOT_APP_ID = "your_bot_application_id_here" # Your bot's application ID
BOT_SUPPORT_GUILD_ID = "your_support_guild_id_here" # Your bot's support server ID
BOT_SHARDS = 1 # Number of shards to spawn
BOT_SHARDS_PER_CLUSTER = 1 # Number of shards per cluster