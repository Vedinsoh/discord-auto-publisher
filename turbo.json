{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "//#check": {},
    "//#check:fix": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:bot-api": {
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "dev:bot-core": {
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "clean": {
      "cache": false
    }
  }
}
