{
  "name": "discord-auto-publisher",
  "version": "7.0.0",
  "author": "Vedinsoh",
  "license": "GPL-3.0-or-later",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "check-types": "turbo run check-types",
    "check": "bunx @biomejs/biome check .",
    "check:fix": "bunx @biomejs/biome check . --write",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "dev:start": "sh ./scripts/bot/dev/start.sh",
    "dev:watch": "sh ./scripts/bot/dev/start.sh --watch",
    "dev:stop": "sh ./scripts/bot/dev/stop.sh",
    "dev:logs": "sh ./scripts/bot/dev/logs.sh",
    "dev:ps": "sh ./scripts/bot/dev/ps.sh",
    "dev:cache": "sh ./scripts/bot/dev/cache.sh",
    "dev:web": "turbo run dev --filter=web",
    "build:web": "turbo run build --filter=web",
    "prod:start": "sh ./scripts/bot/prod/start.sh",
    "prod:stop": "sh ./scripts/bot/prod/stop.sh",
    "prod:logs": "sh ./scripts/bot/prod/logs.sh",
    "prod:ps": "sh ./scripts/bot/prod/ps.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "rimraf": "^6.1.2",
    "supabase": "^2.76.16",
    "turbo": "^2.6.3",
    "typescript": "5.9.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.4",
  "engines": {
    "node": ">=22"
  }
}
